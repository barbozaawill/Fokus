<Window x:Class="Fokus.Views.NewTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fokus.Views"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="NewTaskWindow" Height="1000" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBox   x:Name="AdicionarTasks"
                       Grid.Row="1" 
                       Style="{StaticResource SearchBarTask}"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="20,0,20,0" Height="40"/>

            <Label IsHitTestVisible="False"
                   Content="Adicionar Tasks"
                   Grid.Row="1"
                   VerticalAlignment="Center"
                   Margin="40 10"
                   Foreground="{StaticResource Borders}"
                   FontSize="16"
                   Visibility="{Binding Text.IsEmpty, ElementName=AdicionarTasks, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <ComboBox Grid.Column="1"
                      Width="130"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Margin="0 0 5 0"
                      Height="40"/>
        </Grid>

        <Grid Grid.Row="1">

            <TextBox x:Name="DescricaoDaTask"
                     AcceptsReturn="True"
                     Grid.Row="1"
                     Style="{StaticResource TextBoxDescription}"
                     VerticalContentAlignment="Top"
                     TextWrapping="Wrap"
                     Margin="17"
                     Height="160"
                     FontSize="12"
                     Padding="17"
                     Foreground="{StaticResource PlaceholderBorder}"/>

            <Label IsHitTestVisible="False"
                   Content="Descrição da task"
                   Grid.Row="1"
                   VerticalAlignment="Top"
                   Foreground="{StaticResource PlaceholderBorderText}"
                   HorizontalAlignment="Left"
                   Margin="30 30 0 0"
                   Padding="8"
                   Visibility="{Binding Text.IsEmpty, ElementName=DescricaoDaTask, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        </Grid>

    </Grid>
</Window>
    
    
